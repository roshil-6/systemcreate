{
  "version": 2,
  "installCommand": "npm install && cd server && npm install && cd ../client && npm install",
  "buildCommand": "cd client && CI=false npm run build",
  "outputDirectory": "client/build",
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://crm-2b00.onrender.com/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://crm-2b00.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
