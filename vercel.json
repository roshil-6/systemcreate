{
    "version": 2,
    "buildCommand": "cd client && npm install && CI=false npm run build",
    "outputDirectory": "client/build",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}